# ── LLM ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=models/gemini-2.5-flash
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=2

# ── Vision ────────────────────────────────────────────────────────────────────
CAMERA_INDEX=0
YOLO_MODEL_PATH=yolov8n.pt
VISION_CONFIDENCE_THRESHOLD=0.5

# ── Audio / STT ───────────────────────────────────────────────────────────────
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
AUDIO_SAMPLE_RATE=16000
AUDIO_RECORD_DURATION=5

# ── Audio / TTS ───────────────────────────────────────────────────────────────
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_OFFLINE_FALLBACK=false

# ── Wake Word ─────────────────────────────────────────────────────────────────
WAKE_WORD=hey aura
WAKE_WORD_THRESHOLD=0.5

# ── Robotics ──────────────────────────────────────────────────────────────────
ROBOTICS_ENABLED=false
SERIAL_PORT=COM3
SERIAL_BAUD_RATE=115200

# ── API Server ────────────────────────────────────────────────────────────────
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
